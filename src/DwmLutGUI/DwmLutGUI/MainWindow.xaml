<Window x:Class="DwmLutGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DwmLutGUI"
        mc:Ignorable="d"
        Title="DWM LUT Modern" Height="540" Width="760" MinHeight="420" MinWidth="620">
    <Window.DataContext>
        <local:MainViewModel />
    </Window.DataContext>
    <DockPanel Background="{StaticResource BackgroundBrush}">
        <StatusBar DockPanel.Dock="bottom">
            <TextBlock Text="{Binding ActiveText, StringFormat=Status: {0}}" />
        </StatusBar>
        <DockPanel Margin="6" Background="{StaticResource BackgroundBrush}">
            <Border DockPanel.Dock="Top" Margin="0,0,0,8" Padding="10" BorderBrush="#555555" BorderThickness="1" Background="#202020">
                <StackPanel>
                    <TextBlock Text="Quick path: 1 select a monitor, 2 browse for your SDR/HDR LUT, 3 keep Compatibility on Auto, 4 Apply."
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding CompatibilityModeDetail}" Margin="0,4,0,0" Foreground="#C8C8C8" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
            <Grid DockPanel.Dock="Top" Margin="0,0,0,6" Background="{StaticResource BackgroundBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Margin="0,0,0,6" Text="2 SDR LUT" TextAlignment="Right" />
                <TextBox IsEnabled="{Binding SelectedMonitor, TargetNullValue=false}"
                         Text="{Binding SdrLutPath, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True"
                         Grid.Row="0" Grid.Column="1" Width="Auto" Margin="6,0,6,6" />
                <Button IsEnabled="{Binding SelectedMonitor, TargetNullValue=false}" Grid.Row="0" Grid.Column="2"
                        Content="Browse..."
                        Width="75" Margin="0,0,6,6" VerticalAlignment="Bottom" Click="SdrLutBrowse_Click" />
                <Button IsEnabled="{Binding SdrLutPath, TargetNullValue=false}" Grid.Row="0" Grid.Column="3"
                        Content="Clear"
                        Width="75" Margin="0,0,0,6" Click="SdrLutClear_Click" />
                <TextBlock Grid.Row="1" Grid.Column="0" Text="2 HDR LUT" TextAlignment="Right" />
                <TextBox Grid.Row="1" IsEnabled="{Binding SelectedMonitor, TargetNullValue=false}"
                         Text="{Binding HdrLutPath, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True"
                         Grid.Column="1" Width="Auto" Margin="6,0,6,0" />
                <Button Grid.Row="1" IsEnabled="{Binding SelectedMonitor, TargetNullValue=false}" Grid.Column="2"
                        Content="Browse..."
                        Width="75" Margin="0,0,6,0" VerticalAlignment="Bottom" Click="HdrLutBrowse_Click" />
                <Button Grid.Row="1" IsEnabled="{Binding HdrLutPath, TargetNullValue=false}" Grid.Column="3"
                        Content="Clear"
                        Width="75" Click="HdrLutClear_Click" />
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Cycle LUT key" TextAlignment="Right" Margin="0,6,0,0"
                           ToolTip="Optional: cycles through saved LUT choices for the selected monitor. It does not turn DWM LUT on or off." />
                <ComboBox x:Name="ToggleKeyCombo" Grid.Row="2" Grid.Column="1" Margin="6,6,6,0"
                          SelectedItem="{Binding ToggleKey}" HorizontalAlignment="Left" Width="160"
                          ToolTip="Optional: cycles through saved LUT choices for the selected monitor. It does not turn DWM LUT on or off." />
                <TextBlock Grid.Row="3" Grid.Column="0" Text="3 Compatibility" TextAlignment="Right" Margin="0,6,0,0" />
                <ComboBox Grid.Row="3" Grid.Column="1" Margin="6,6,6,0" HorizontalAlignment="Left" Width="260"
                          ItemsSource="{Binding ResolverModes}"
                          DisplayMemberPath="Label"
                          SelectedValuePath="Value"
                          SelectedValue="{Binding ResolverMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          ToolTip="{Binding CompatibilityModeDetail}" />
                <TextBlock Grid.Row="4" Grid.Column="0" Text="DWM" TextAlignment="Right" Margin="0,6,0,0" />
                <TextBlock Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="3" Margin="6,6,0,0"
                           Text="{Binding SupportText}" ToolTip="{Binding SupportDetail}" TextWrapping="Wrap" />
            </Grid>
            <Grid DockPanel.Dock="Bottom">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button Content="About" Width="75" Click="AboutButton_Click" />
                    <Button Content="How to use" Margin="6,0,0,0" Padding="12,3" Click="HowToButton_Click" />
                </StackPanel>
                <WrapPanel HorizontalAlignment="Right">
                    <Button IsEnabled="{Binding CanApply}" Content="4 Apply" Width="75" Margin="0,0,6,0"
                            Click="Apply_Click" />
                    <Button Content="Disable" Width="75" IsEnabled="{Binding IsActive}"
                            Click="Disable_Click" />
                </WrapPanel>
            </Grid>
            <DataGrid SelectedItem="{Binding SelectedMonitor}" ItemsSource="{Binding Monitors}" RowHeaderWidth="0"
                      IsReadOnly="{Binding IsActive}" AutoGenerateColumns="False" DockPanel.Dock="Bottom" Margin="0,0,0,6"
                      CanUserReorderColumns="False" CanUserSortColumns="False" CanUserResizeColumns="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="#" Binding="{Binding SourceId}" IsReadOnly="True" />
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" IsReadOnly="True" />
                    <DataGridTextColumn Header="Connector" Binding="{Binding Connector}" IsReadOnly="True" />
                    <DataGridTextColumn Header="Position" Binding="{Binding Position}" IsReadOnly="True" />
                    <DataGridTemplateColumn Header="SDR LUT" Width="*" IsReadOnly="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding SdrLutFilename, Mode=OneWay}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding SdrLuts}" SelectedItem="{Binding SdrLutPath, UpdateSourceTrigger=PropertyChanged}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn>
                        <DataGridTemplateColumn.HeaderTemplate>
                            <DataTemplate>
                                <Button Content="-" Click="RemoveSdrLut_Click" />
                            </DataTemplate>
                        </DataGridTemplateColumn.HeaderTemplate>
                    </DataGridTemplateColumn>
                    
                    <DataGridTemplateColumn Header="HDR LUT" Width="*" IsReadOnly="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding HdrLutFilename, Mode=OneWay}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding HdrLuts}" SelectedItem="{Binding HdrLutPath, UpdateSourceTrigger=PropertyChanged}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn>
                        <DataGridTemplateColumn.HeaderTemplate>
                            <DataTemplate>
                                <Button Content="-" Click="RemoveHdrLut_Click" />
                            </DataTemplate>
                        </DataGridTemplateColumn.HeaderTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </DockPanel>
</Window>
